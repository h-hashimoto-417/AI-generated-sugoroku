<div class="content-right">
    <button class="login-button">ログイン</button>
</div>
<h1 class="home-header">
    <span class="title-ai">
     <%= image_tag "heart.PNG", class: "heart-bg" %>
     AI
    </span>
    <span class="title-suru">する</span>
    <span class="title-sugoroku">スゴロク</span>
</h1>
<%= form_with url: "/home/generate", method: :post, data: { turbo: false } do %>
    <div class="content-center">
        <textarea 
            name="prompt"
            placeholder="どんなスゴロクを作りたいか（例：テーマや設定）を入力してください"
            class="prompt-input"
        ></textarea>
    </div>
    <div class="content-center">
        <button 
        type="submit"
        class="generate-button"
        >生成</button>
    </div>
<% end %>
