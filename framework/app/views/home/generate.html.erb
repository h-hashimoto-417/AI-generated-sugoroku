<div class="header">
    <h1 class="site-title">AIするスゴロク</h1>
    <button class="login-button">ログイン</button>
</div>
<div class="content-center">
    <h2 class="show-result">生成完了！</h2>
    <div class="sugoroku-display">
      <div id="board">
        <% @sugoroku.each do |cell| %>
          <div class="square">
            <%= cell["text"] %>
          </div>
        <% end %>
      </div>
    </div>
</div>
<div class="content-sidebyside">
    <button class="action-button" onclick="location.href='/play'">遊ぶ</button>
    <button class="action-button" onclick="location.href='/home'">再生成</button>
</div>
