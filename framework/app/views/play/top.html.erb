<div class="header">
    <h1 class="site-title">AI生成スゴロク</h1>
    <button class="login-button">ログイン</button>
</div>

<div id="player-modal" class="modal">

  <div class="modal-content">
    <h2>プレイヤー登録</h2>
    <div class="content-sidebyside">

    <h3>プレイヤー人数</h3>
    <input
        type="number"
        min="1"
        max="4"
        value="2"
        class="player-count"
    >

</div>
    <button onclick="closeModal()">
      決定
    </button>
    <script>
        function closeModal() {

        document
        .getElementById("player-modal")
        .style.display = "none";
        }
    </script>
</div>

</div>